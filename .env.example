# =============================================================================
# Lease Reviewer - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# Google Gemini API key (get one from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Docling service endpoint (internal docker network)
DOCLING_URL=http://docling:5001

# Docling request timeout in seconds (PDF conversion can be slow)
DOCLING_TIMEOUT=300

# Model to use via LiteLLM (default: Gemini 2.5 Flash)
# See https://docs.litellm.ai/docs/providers for other model strings
AGENT_MODEL=gemini/gemini-2.5-flash

# Suppress ADK's suggestion to use native Gemini instead of LiteLLM
# (we use LiteLLM intentionally to keep the model layer swappable)
ADK_SUPPRESS_GEMINI_LITELLM_WARNINGS=true
